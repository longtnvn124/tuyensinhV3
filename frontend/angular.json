{
    "$schema"        : "node_modules/@angular/cli/lib/config/schema.json" ,
    "version"        : 1 ,
    "newProjectRoot" : "projects" ,
    "projects"       : {
        "dacms" : {
            "projectType" : "application" ,
            "schematics"  : {
                "@schematics/angular:component"   : {
                    "type"      : "component" ,
                    "skipTests" : true
                } ,
                "@schematics/angular:service"     : {
                    "type"      : "service" ,
                    "skipTests" : true
                } ,
                "@schematics/angular:directive"   : {
                    "type"      : "directive" ,
                    "skipTests" : true
                } ,
                "@schematics/angular:pipe"        : {
                    "typeSeparator" : "." ,
                    "skipTests"     : true
                } ,
                "@schematics/angular:guard"       : {
                    "typeSeparator" : "." ,
                    "skipTests"     : true
                } ,
                "@schematics/angular:interceptor" : {
                    "typeSeparator" : "." ,
                    "skipTests"     : true
                } ,
                "@schematics/angular:module"      : {
                    "typeSeparator" : "."
                } ,
                "@schematics/angular:resolver"    : {
                    "typeSeparator" : "." ,
                    "skipTests"     : true
                }
            } ,
            "root"        : "" ,
            "sourceRoot"  : "src" ,
            "prefix"      : "app" ,
            "architect"   : {
                "build"        : {
                    "builder"              : "@angular/build:application" ,
                    "options"              : {
                        "allowedCommonJsDependencies" : [ "crypto-js" , "apexcharts" , "dayjs" , "file-saver" , "lodash" , "jszip" , "plyr" , "loadjs" , "rangetouch" , "@ckeditor/ckeditor5-build-classic" , "buffer" , "exceljs" ] ,
                        "outputPath"                  : "dist/dacms" ,
                        "index"                       : "src/index.html" ,
                        "polyfills"                   : [ "zone.js" ] ,
                        "tsConfig"                    : "tsconfig.app.json" ,
                        "assets"                      : [
                            "src/favicon.ico" ,
                            "src/assets" ,
                            {
                                "glob"   : "**/*" ,
                                "input"  : "public" ,
                                "output" : "/"
                            } ,
                            {
                                "glob"   : "**/*" ,
                                "input"  : "node_modules/ngx-extended-pdf-viewer/assets" ,
                                "output" : "/assets/"
                            } ,
                            {
                                "glob"   : "**/*" ,
                                "input"  : "node_modules/tinymce" ,
                                "output" : "/tinymce/"
                            }
                        ] ,
                        "styles"                      : [
                            "src/vendors/dear-flip/dflip.min.css" ,
                            "src/app/module/ngx-file-preview/assets/icon/font/nfp.css" ,
                            "node_modules/plyr/dist/plyr.css" ,
                            "node_modules/primeicons/primeicons.css" ,
                            "src/css/fontawesome-pro-v7.1.0/all.css" ,
                            "src/css/fontawesome-pro-v7.1.0/duotone-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/fontawesome.css" ,
                            "src/css/fontawesome-pro-v7.1.0/light.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-duotone-light.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-light.css" ,
                            "src/css/fontawesome-pro-v7.1.0/slab-press-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/svg.css" ,
                            "src/css/fontawesome-pro-v7.1.0/utility-fill-semibold.css" ,
                            "src/css/fontawesome-pro-v7.1.0/v5-font-face.css" ,
                            "src/css/fontawesome-pro-v7.1.0/brands.css" ,
                            "src/css/fontawesome-pro-v7.1.0/duotone-thin.css" ,
                            "src/css/fontawesome-pro-v7.1.0/jelly-duo-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/notdog-duo-solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-duotone-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/slab-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/thin.css" ,
                            "src/css/fontawesome-pro-v7.1.0/utility-semibold.css" ,
                            "src/css/fontawesome-pro-v7.1.0/whiteboard-semibold.css" ,
                            "src/css/fontawesome-pro-v7.1.0/chisel-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/duotone.css" ,
                            "src/css/fontawesome-pro-v7.1.0/jelly-fill-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/notdog-solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-duotone-solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/thumbprint-light.css" ,
                            "src/css/fontawesome-pro-v7.1.0/v4-font-face.css" ,
                            "src/css/fontawesome-pro-v7.1.0/duotone-light.css" ,
                            "src/css/fontawesome-pro-v7.1.0/etch-solid.css" ,
                            "src/css/fontawesome-pro-v7.1.0/jelly-regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/regular.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-duotone-thin.css" ,
                            "src/css/fontawesome-pro-v7.1.0/sharp-thin.css" ,
                            "src/css/fontawesome-pro-v7.1.0/svg-with-js.css" ,
                            "src/css/fontawesome-pro-v7.1.0/utility-duo-semibold.css" ,
                            "src/css/fontawesome-pro-v7.1.0/v4-shims.css" ,
                            "src/css/bootstrap-utilities.css" ,
                            "src/scss/fonts/tabler-icons.min.css" ,
                            "src/css/prefix.css" ,
                            "src/css/custom-button.css" ,
                            "src/styles.scss" ,
                            "src/app/theme/styles/material-overrides.scss" ,
                            "src/css/animation.css" ,
                            "src/css/base.css" ,
                            "src/css/common.css" ,
                            "src/css/dashboard.css" ,
                            "src/css/secondary.css" ,
                            "src/css/third.css" ,
                            "src/css/tinymce.css"
                        ] ,
                        "scripts"                     : [
                            "node_modules/jquery/dist/jquery.min.js" ,
                            "src/vendors/dear-flip/dflip.min.js" ,
                            "node_modules/apexcharts/dist/apexcharts.min.js" ,
                            "src/app/module/ngx-file-preview/assets/icon/color/nfp.js"
                        ] ,
                        "stylePreprocessorOptions"    : {
                            "includePaths" : [ "mixed-decls" , "color-functions" , "global-builtin" , "import" ]
                        } ,
                        "browser"                     : "src/main.ts"
                    } ,
                    "configurations"       : {
                        "production"  : {
                            "budgets"          : [
                                {
                                    "type"           : "initial" ,
                                    "maximumWarning" : "20mb" ,
                                    "maximumError"   : "20mb"
                                } ,
                                {
                                    "type"           : "anyComponentStyle" ,
                                    "maximumWarning" : "4mb" ,
                                    "maximumError"   : "8mb"
                                }
                            ] ,
                            "fileReplacements" : [
                                {
                                    "replace" : "src/environments/environment.ts" ,
                                    "with"    : "src/environments/environment.prod.ts"
                                }
                            ] ,
                            "outputHashing"    : "all" ,
                            "sourceMap"        : false ,
                            "namedChunks"      : false ,
                            "aot"              : true ,
                            "extractLicenses"  : false
                        } ,
                        "development" : {
                            "optimization"    : false ,
                            "extractLicenses" : false ,
                            "sourceMap"       : true ,
                            "namedChunks"     : true
                        }
                    } ,
                    "defaultConfiguration" : "production"
                } ,
                "serve"        : {
                    "builder"              : "@angular/build:dev-server" ,
                    "configurations"       : {
                        "production"  : {
                            "buildTarget" : "dacms:build:production"
                        } ,
                        "development" : {
                            "buildTarget" : "dacms:build:development" ,
                            "port"        : 8008 ,
                            "sslKey"      : "localhost.key" ,
                            "sslCert"     : "localhost.crt" ,
                            "ssl"         : true
                        }
                    } ,
                    "defaultConfiguration" : "development" ,
                    "options"              : {
                        "hmr" : false
                    }
                } ,
                "extract-i18n" : {
                    "builder" : "@angular/build:extract-i18n"
                } ,
                "test"         : {
                    "builder" : "@angular/build:karma" ,
                    "options" : {
                        "polyfills" : [
                            "zone.js" ,
                            "zone.js/testing"
                        ] ,
                        "tsConfig"  : "tsconfig.spec.json" ,
                        "assets"    : [
                            {
                                "glob"  : "**/*" ,
                                "input" : "public"
                            }
                        ] ,
                        "styles"    : [
                            "src/styles.css"
                        ] ,
                        "scripts"   : [ ]
                    }
                }
            }
        }
    } ,
    "cli"            : {
        "analytics" : "5dd17ba5-9f06-491d-836a-a8855ac0232b"
    }
}
